<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="muon_mfa_token" resource="default" engine="innodb"
           comment="Muon MultiFactorLogin - MFA Tokens">
        <column xsi:type="int" name="token_id" padding="10" unsigned="true" nullable="false"
                identity="true" comment="Token ID"/>
        <column xsi:type="int" name="customer_id" padding="10" unsigned="true" nullable="false"
                comment="Customer ID"/>
        <column xsi:type="varchar" name="token" nullable="false" length="64"
                comment="SHA-256 hashed one-time token"/>
        <column xsi:type="varchar" name="delivery_method" nullable="false" length="10"
                comment="Delivery method: sms or email"/>
        <column xsi:type="smallint" name="is_used" padding="5" unsigned="true" nullable="false"
                default="0" comment="0 = active, 1 = consumed or invalidated"/>
        <column xsi:type="int" name="verify_attempts" padding="10" unsigned="true" nullable="false"
                default="0" comment="Number of failed verification attempts"/>
        <column xsi:type="datetime" name="expires_at" nullable="false"
                comment="Token expiry datetime (UTC)"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP"
                comment="Token creation datetime (UTC)"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="token_id"/>
        </constraint>

        <!-- Active token lookup: WHERE customer_id = ? AND is_used = 0 AND expires_at >= NOW() -->
        <index referenceId="MUON_MFA_TOKEN_CUSTOMER_ID_IS_USED_EXPIRES_AT" indexType="btree">
            <column name="customer_id"/>
            <column name="is_used"/>
            <column name="expires_at"/>
        </index>
        <!-- Rate limit query: WHERE customer_id = ? AND created_at >= ? -->
        <index referenceId="MUON_MFA_TOKEN_CUSTOMER_ID_CREATED_AT" indexType="btree">
            <column name="customer_id"/>
            <column name="created_at"/>
        </index>
        <!-- Cleanup cron: WHERE expires_at < NOW() -->
        <index referenceId="MUON_MFA_TOKEN_EXPIRES_AT" indexType="btree">
            <column name="expires_at"/>
        </index>
    </table>
</schema>
